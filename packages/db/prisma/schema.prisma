
generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  members     Member[]
  invitations Invitation[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeOrganizationId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id          String       @id
  name        String
  slug        String
  logo        String?
  createdAt   DateTime
  metadata    String?

  // Subscription
  polarCustomerId       String?
  subscriptionId        String?
  subscriptionActive    Boolean  @default(false)
  subscriptionPlanName  String?
  cancelAtPeriodEnd     Boolean  @default(false)

  members              Member[]
  invitations          Invitation[]
  monitors             Monitor[]
  statusPages          StatusPage[]
  notificationChannels NotificationChannel[]

  @@unique([slug])
  @@map("organization")
}

model Monitor {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  type        String   // "http" | "tcp"
  active      Boolean  @default(true)
  interval    Int      @default(60) // seconds
  timeout     Int      @default(10) // seconds

  // HTTP-specific
  url         String?
  method      String?  @default("GET")
  headers     Json?    // { "key": "value" }
  body        String?

  // TCP-specific
  host        String?
  port        Int?

  // Assertion rules: [{ type: "status", operator: "eq", value: "200" }]
  rules       Json?

  // Regions to ping from: ["eu", "us", "asia"]
  regions     Json     @default("[]")

  autoIncidents Boolean @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastCheckedAt DateTime?
  nextCheckAt   DateTime?
  lastStatus    String?
  lastLatency   Int?
  lastStatusCode Int?
  lastRegion    String?
  lastMessage   String?
  checks      MonitorCheck[]
  hourlyRollups MonitorCheckHourlyRollup[]
  dailyRollups  MonitorCheckDailyRollup[]
  statusPageMonitors StatusPageMonitor[]
  incidents   Incident[]
  dependencies MonitorDependency[]

  @@index([organizationId])
  @@index([active])
  @@index([active, nextCheckAt])
  @@map("monitor")
}

model MonitorCheck {
  id        String   @id @default(cuid())
  monitorId String
  monitor   Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  status          String   // "up" | "down" | "degraded"
  latency         Int      // ms
  statusCode      Int?
  message         String?
  region          String?
  responseHeaders Json?
  responseBody    String?
  checkedAt       DateTime @default(now())

  @@index([monitorId, checkedAt])
  @@map("monitor_check")
}

model MonitorCheckHourlyRollup {
  monitorId       String
  monitor         Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  bucketStart     DateTime
  totalChecks     Int
  upChecks        Int
  downChecks      Int
  degradedChecks  Int
  latencySum      Int

  @@id([monitorId, bucketStart])
  @@index([bucketStart])
  @@map("monitor_check_hourly_rollup")
}

model MonitorCheckDailyRollup {
  monitorId       String
  monitor         Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  bucketDate      DateTime
  totalChecks     Int
  upChecks        Int
  downChecks      Int
  degradedChecks  Int
  latencySum      Int

  @@id([monitorId, bucketDate])
  @@index([bucketDate])
  @@map("monitor_check_daily_rollup")
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

model StatusPage {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  slug        String
  customDomain String?
  isPublic    Boolean  @default(true)

  // Customization
  logoUrl            String?
  faviconUrl         String?
  brandColor         String?  @default("#000000")
  headerText         String?
  footerText         String?
  customCss          String?
  customJs           String?
  showResponseTimes  Boolean  @default(true)
  showDependencies   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  monitors    StatusPageMonitor[]
  subscribers StatusPageSubscriber[]

  @@unique([slug])
  @@unique([customDomain])
  @@index([organizationId])
  @@map("status_page")
}

model StatusPageSubscriber {
  id           String     @id @default(cuid())
  statusPageId String
  statusPage   StatusPage @relation(fields: [statusPageId], references: [id], onDelete: Cascade)
  email        String
  monitorIds   Json       @default("[]")
  verified     Boolean    @default(false)
  token        String     @unique @default(cuid())
  createdAt    DateTime   @default(now())

  @@unique([statusPageId, email])
  @@index([statusPageId])
  @@map("status_page_subscriber")
}

model StatusPageMonitor {
  id           String     @id @default(cuid())
  statusPageId String
  statusPage   StatusPage @relation(fields: [statusPageId], references: [id], onDelete: Cascade)
  monitorId    String
  monitor      Monitor    @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  sortOrder    Int        @default(0)
  displayName  String?
  groupName    String?

  @@unique([statusPageId, monitorId])
  @@index([statusPageId])
  @@map("status_page_monitor")
}

model Incident {
  id        String   @id @default(cuid())
  monitorId String
  monitor   Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  title     String
  status    String   @default("investigating") // investigating | identified | monitoring | resolved
  severity  String   @default("minor")         // minor | major | critical
  startedAt DateTime @default(now())
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updates   IncidentUpdate[]

  @@index([monitorId])
  @@index([status])
  @@map("incident")
}

model IncidentUpdate {
  id         String   @id @default(cuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  status     String   // investigating | identified | monitoring | resolved
  message    String
  createdAt  DateTime @default(now())

  @@index([incidentId])
  @@map("incident_update")
}

model NotificationChannel {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name           String
  type           String   // "discord" | "email"
  webhookUrl     String?  // Required for discord
  recipientEmail String?  // Required for email
  enabled        Boolean  @default(true)

  // Events to notify on
  onIncidentCreated  Boolean @default(true)
  onIncidentResolved Boolean @default(true)
  onIncidentUpdated  Boolean @default(true)
  onMonitorDown      Boolean @default(true)
  onMonitorRecovered Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([organizationId])
  @@map("notification_channel")
}

// --- Global Status Registry ---

model ExternalService {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  website       String?
  logoUrl       String?
  category      String   // "hosting" | "cdn" | "database" | "api" | "devtools" | "cloud" | "payments" | "communication" | "auth"

  // Status page parsing
  statusPageUrl    String?
  statusPageApiUrl String?
  parserType       String   @default("atlassian") // "atlassian" | "custom_json"
  parserConfig     Json?

  // Polling
  pollInterval  Int      @default(300) // seconds
  active        Boolean  @default(true)

  // Cached current status
  currentStatus      String?  // "operational" | "degraded_performance" | "partial_outage" | "major_outage" | "maintenance" | "unknown"
  currentDescription String?
  lastFetchedAt      DateTime?
  lastFetchError     String?
  nextFetchAt        DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  components    ExternalServiceComponent[]
  statusHistory ExternalServiceStatus[]
  dependencies  MonitorDependency[]

  @@index([category])
  @@index([active, nextFetchAt])
  @@map("external_service")
}

model ExternalServiceComponent {
  id                String          @id @default(cuid())
  externalServiceId String
  externalService   ExternalService @relation(fields: [externalServiceId], references: [id], onDelete: Cascade)

  externalId    String?
  name          String
  description   String?
  groupName     String?
  currentStatus String?

  updatedAt     DateTime @updatedAt

  dependencies  MonitorDependency[]

  @@unique([externalServiceId, externalId])
  @@index([externalServiceId])
  @@map("external_service_component")
}

model ExternalServiceStatus {
  id                String          @id @default(cuid())
  externalServiceId String
  externalService   ExternalService @relation(fields: [externalServiceId], references: [id], onDelete: Cascade)

  status           String
  description      String?
  incidentName     String?
  componentStatuses Json?

  checkedAt        DateTime @default(now())

  @@index([externalServiceId, checkedAt])
  @@map("external_service_status")
}

model MonitorDependency {
  id                  String   @id @default(cuid())
  monitorId           String
  monitor             Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  externalServiceId   String
  externalService     ExternalService @relation(fields: [externalServiceId], references: [id], onDelete: Cascade)
  externalComponentId String?
  externalComponent   ExternalServiceComponent? @relation(fields: [externalComponentId], references: [id], onDelete: SetNull)
  note                String?

  createdAt           DateTime @default(now())

  @@unique([monitorId, externalServiceId, externalComponentId])
  @@index([monitorId])
  @@index([externalServiceId])
  @@map("monitor_dependency")
}
