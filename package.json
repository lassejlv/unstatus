{
  "name": "unstatus",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --parallel dev:web dev:worker",
    "dev:web": "bun run --filter web dev",
    "dev:worker": "bun run --filter worker dev",
    "dev:worker-rs": "cargo run --manifest-path apps/worker-rs/Cargo.toml",
    "dev:docs": "bun run --filter docs dev",
    "build": "bun run build:web",
    "build:web": "bun run db:migrate:deploy && bun run db:generate && bun run --filter web build",
    "build:worker": "bun run db:generate && bun run --filter worker build",
    "build:worker-rs": "cargo build --release --manifest-path apps/worker-rs/Cargo.toml",
    "start": "bun run start:web",
    "start:web": "bun run --filter web start",
    "start:worker-rs": "cargo run --release --manifest-path apps/worker-rs/Cargo.toml",
    "bauth": "bun run --filter web bauth",
    "lint": "bunx oxlint apps/web/src apps/worker/src packages/db",
    "check:worker-rs": "cargo check --manifest-path apps/worker-rs/Cargo.toml",
    "db:generate": "bun run --filter @unstatus/db prisma:generate",
    "db:migrate:deploy": "bun run --filter @unstatus/db prisma:migrate:deploy",
    "db:migrate:dev": "bun run --filter @unstatus/db prisma:migrate:dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "overrides": {
    "@better-auth/core": "1.5.6"
  },
  "dependencies": {
    "@react-email/components": "^1.0.10",
    "inboundemail": "^0.20.0"
  }
}
