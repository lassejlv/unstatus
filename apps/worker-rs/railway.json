{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "buildCommand": "cargo build --release && install -Dm755 target/release/worker-rs bin/worker-rs"
  },
  "deploy": {
    "startCommand": "./bin/worker-rs",
    "sleepApplication": false,
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 67
  }
}
