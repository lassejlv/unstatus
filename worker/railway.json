{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun build --compile --minify src/index.ts --outfile worker"
  },
  "deploy": {
    "startCommand": "./worker",
    "sleepApplication": false,
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 67
  }
}
